<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="API Key 設定"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <Switch
            android:id="@+id/switchAutoRotate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自動切換 "
            android:checked="true"
            android:layout_marginEnd="16dp"/>

        <Button android:id="@+id/btnCancelDelete" android:layout_width="40dp" android:layout_height="40dp" android:text="X" android:backgroundTint="#888888" android:textColor="@color/white" android:layout_marginEnd="8dp" android:minWidth="0dp" android:padding="0dp" android:visibility="gone"/>
        <Button android:id="@+id/btnConfirmDelete" android:layout_width="40dp" android:layout_height="40dp" android:text="V" android:backgroundTint="#D32F2F" android:textColor="@color/white" android:layout_marginEnd="8dp" android:minWidth="0dp" android:padding="0dp" android:visibility="gone"/>

        <Button android:id="@+id/btnEnterDeleteMode" android:layout_width="40dp" android:layout_height="40dp" android:text="-" android:backgroundTint="#2A4B3C" android:textColor="@color/white" android:layout_marginEnd="8dp" android:minWidth="0dp" android:padding="0dp"/>
        <Button android:id="@+id/btnAddKey" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:backgroundTint="#2A4B3C" android:textColor="@color/white" android:minWidth="0dp" android:padding="0dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewApiKeys"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>